# Supabase Configuration (Real-time Food Listings Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Neon PostgreSQL Configuration (User Profiles & Order History)
DATABASE_URL=postgresql://user:password@host:5432/database

# Groq AI Configuration (Voice Assistant)
GROQ_API_KEY=your-groq-api-key

# Upstash Redis Configuration (Cache Popular Offers)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Upstash Vector Configuration (Neighborhood Search)
UPSTASH_VECTOR_REST_URL=https://your-vector-url.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your-vector-token

# Vercel Blob Configuration (Photo Uploads)
BLOB_READ_WRITE_TOKEN=your-blob-token
